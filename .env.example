# --- Google Sheets + Drive sync -------------------------------------------
# Pick ONE of these two ways to supply the service-account credentials.
#
# (A) LOCAL DEV — path to a JSON key file on your machine (outside the repo).
GOOGLE_SERVICE_ACCOUNT_JSON=/absolute/path/to/service-account.json
#
# (B) PRODUCTION — paste the JSON contents directly (or base64 of it).
#     Use this on Vercel/Render/Railway/etc. where you can't ship a file.
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# Your sheet ID (from the URL: docs.google.com/spreadsheets/d/<THIS_PART>/edit)
GOOGLE_SHEET_ID=1blaeIiEpzSkQppM88j6VjiqTyNgrwvpEgEg8tw54F90

# Tab name inside that sheet. Default: Sheet1
GOOGLE_SHEET_TAB=Sheet1

# Drive folder ID where photos will be uploaded.
# Get it from the folder URL: drive.google.com/drive/folders/<THIS_PART>
GOOGLE_DRIVE_FOLDER_ID=1_r1k5g1yLmEKb1Z-Kik8SZTNveiwsQYn

# Optional: skip cloud sync entirely (still records locally). Useful in dev.
# SYNC_DISABLED=1

